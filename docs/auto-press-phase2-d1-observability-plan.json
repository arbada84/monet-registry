{
  "document": {
    "title": "보도자료 자동등록 2단계 D1 작업 큐 및 관리자 관측성 상세 기획서",
    "version": "2026-05-11",
    "status": "implemented",
    "language": "ko-KR",
    "parentPlans": [
      "docs/auto-press-vercel-cpu-distribution-plan.json",
      "docs/auto-press-phase1-vercel-cpu-defense-plan.json"
    ],
    "developmentStarted": true,
    "summary": "자동등록 실행 상태, 기사 후보 처리 결과, 실패 사유, 비용 보호 지표를 Cloudflare D1에 구조적으로 저장하고 관리자 화면에서 확인할 수 있게 한다."
  },
  "purpose": {
    "why": "현재 수동 실행이나 자동 실행 후 어떤 기사가 등록됐고, 어떤 기사가 실패했으며, 왜 실패했는지 운영자가 확인하기 어렵다.",
    "goal": "자동등록을 블랙박스가 아니라 관측 가능한 작업 시스템으로 바꾼다.",
    "result": "운영자는 버튼을 누른 뒤 실행 ID, 후보 수, 큐 대기 수, 처리 상태, 기사별 실패 사유, 소스별 품질을 화면에서 확인할 수 있다."
  },
  "storageDecision": {
    "rationale": "현재 프로젝트는 Cloudflare D1을 활성 DB로 사용하며 auto_press_runs/items/events/retry_queue migration이 이미 존재한다. run/item/event/source_stats는 D1에 저장하고, Vercel은 src/lib/d1-http-client 경로로, Worker는 D1 binding 또는 동일 D1 API 경로로 접근한다.",
    "storage": "Cloudflare D1 (기존 활성 DB)",
    "accessFromVercel": "src/lib/d1-http-client.ts 및 src/lib/auto-press-observability.ts 사용",
    "accessFromWorker": "Cloudflare Worker D1 binding 우선, 필요 시 Cloudflare D1 HTTP API fallback"
  },
  "scope": {
    "included": [
      "D1 auto_press_runs 테이블 설계",
      "D1 auto_press_items 테이블 설계",
      "D1 auto_press_events 테이블 설계",
      "D1 auto_press_source_stats 또는 일일 집계 확장 설계",
      "실행 상태 전이 규칙",
      "기사 후보 상태 전이 규칙",
      "한글 이벤트 코드와 메시지 표준",
      "관리자 조회 API",
      "관리자 화면 구성",
      "성능과 인덱스 설계",
      "데이터 보존 정책"
    ],
    "excluded": [
      "Cloudflare Worker 큐 소비자 구현",
      "AI 편집 로직 고도화",
      "텔레그램 명령 처리 전체 구현",
      "기존 기사 전체 마이그레이션"
    ]
  },
  "operatingPrinciples": [
    {
      "principle": "모든 자동등록 실행은 run으로 남긴다.",
      "description": "수동 실행, cron 실행, 텔레그램 실행, 재시도 실행 모두 auto_press_runs에 기록한다."
    },
    {
      "principle": "모든 기사 후보는 item으로 남긴다.",
      "description": "등록 성공뿐 아니라 중복, 이미지 없음, AI 실패, 저작권 유사도 실패도 auto_press_items에 상태로 남긴다."
    },
    {
      "principle": "운영자가 이해할 수 있는 한글 메시지를 저장한다.",
      "description": "내부 코드는 영문 event_code를 쓰되 관리자 화면에는 한글 message와 failure_message를 우선 노출한다."
    },
    {
      "principle": "AI 호출 전 제외 사유를 분리한다.",
      "description": "이미지 없음, 중복, 소스 품질 제외는 AI 호출 전에 기록해 토큰 절약 효과를 추적한다."
    },
    {
      "principle": "테이블은 추가형으로 설계한다.",
      "description": "기존 articles 데이터에 영향을 주지 않도록 새 테이블만 추가하고 기존 기능과의 충돌을 줄인다."
    },
    {
      "principle": "현재 D1 migration을 재사용하고 누락 컬럼만 additive migration으로 추가한다.",
      "description": "cloudflare/d1/migrations/0002_auto_press_observability.sql에 이미 auto_press_runs, auto_press_items, auto_press_events, auto_press_retry_queue가 존재한다. Phase2 개발 시 이 테이블을 새로 만들지 말고, 기획서에서 필요한 컬럼 중 현재 migration에 없는 항목만 새 migration 파일로 ALTER TABLE 또는 보조 테이블 형태로 추가한다."
    }
  ],
  "implementationCautions": {
    "migrationReuseRule": {
      "status": "mandatory",
      "description": "현재 migration 재사용 + 필요한 컬럼만 additive migration 원칙을 반드시 따른다.",
      "existingMigration": "cloudflare/d1/migrations/0002_auto_press_observability.sql",
      "existingTables": [
        "auto_press_runs",
        "auto_press_items",
        "auto_press_events",
        "auto_press_retry_queue"
      ],
      "do": [
        "기존 테이블명 auto_press_items를 그대로 사용한다.",
        "기존 컬럼 source, started_at, completed_at, reason_code, reason_message, code, metadata_json을 우선 재사용한다.",
        "문서상 추가 설계 컬럼이 필요하면 새 migration 파일을 만들어 ALTER TABLE로 추가한다.",
        "추가 컬럼은 NULL 허용 또는 DEFAULT 값을 둬 기존 row와 기존 API를 깨지 않게 한다.",
        "기존 src/lib/auto-press-observability.ts 타입과 mapper를 먼저 확인한 뒤 컬럼을 추가한다."
      ],
      "doNot": [
        "auto_press_jobs라는 새 테이블을 만들지 않는다.",
        "auto_press_runs/items/events를 DROP 후 재생성하지 않는다.",
        "기존 0002 migration 내용을 수정해 이미 적용된 프로덕션 D1과 불일치시키지 않는다.",
        "기존 reason_code/reason_message를 failure_code/failure_message로 강제 교체하지 않는다.",
        "기존 code/metadata_json을 event_code/meta_json으로 강제 교체하지 않는다."
      ]
    },
    "fieldNameMapping": {
      "description": "기획서의 이상적 필드명과 현재 구현 필드명이 다를 때는 기존 구현명을 우선한다.",
      "mapping": [
        {
          "planned": "trigger_type",
          "existing": "source 또는 triggered_by",
          "guidance": "Phase2 초기에는 existing 필드를 사용하고, 별도 분석에 꼭 필요할 때 trigger_type을 additive로 추가한다."
        },
        {
          "planned": "execution_mode",
          "existing": "options_json.executionMode",
          "guidance": "컬럼 추가 전에는 options_json에 저장해 호환성을 유지한다."
        },
        {
          "planned": "candidate_count",
          "existing": "queued_count 또는 summary_json",
          "guidance": "대시보드 표시가 필요하면 summary_json에서 시작하고, 성능상 필요할 때 컬럼을 추가한다."
        },
        {
          "planned": "failure_code",
          "existing": "reason_code 또는 error_code",
          "guidance": "item 단위는 reason_code, run 단위는 error_code를 사용한다."
        },
        {
          "planned": "failure_message",
          "existing": "reason_message 또는 error_message",
          "guidance": "item 단위는 reason_message, run 단위는 error_message를 사용한다."
        },
        {
          "planned": "event_code",
          "existing": "code",
          "guidance": "auto_press_events.code를 그대로 사용한다."
        },
        {
          "planned": "meta_json",
          "existing": "metadata_json",
          "guidance": "auto_press_events.metadata_json을 그대로 사용한다."
        },
        {
          "planned": "external_id",
          "existing": "source_item_id",
          "guidance": "외부 보도자료 번호 또는 RSS GUID는 source_item_id에 저장한다."
        }
      ]
    },
    "queueNamingCaution": {
      "description": "Phase3 Queue 이름은 기존 기획상 auto-press-jobs로 되어 있으나 메시지와 테이블은 item 기준이다.",
      "guidance": "기능상 문제는 없지만, 개발 중 혼선을 줄이려면 코드 내부 타입은 AutoPressItemMessage, itemId를 사용한다. Cloudflare Queue 리소스 이름은 운영 설정 영향이 있으므로 생성 전 auto-press-jobs 또는 auto-press-items 중 하나로 최종 확정한다."
    }
  },
  "databaseSchema": {
    "auto_press_runs": {
      "description": "자동등록 실행 단위. 버튼 클릭 1회, cron 1회, 텔레그램 명령 1회가 하나의 run이 된다. 저장소: Cloudflare D1.",
      "columns": [
        { "name": "id", "type": "TEXT", "required": true, "description": "UUID 또는 ulid 실행 ID" },
        { "name": "trigger_type", "type": "TEXT", "required": true, "description": "manual, cron, telegram, retry, system" },
        { "name": "execution_mode", "type": "TEXT", "required": true, "description": "queue_only, limited_immediate, worker" },
        { "name": "status", "type": "TEXT", "required": true, "description": "queued, collecting, waiting_worker, processing, completed, failed, cancelled" },
        { "name": "source_filter_json", "type": "TEXT", "required": false, "description": "선택된 소스, 날짜 범위, 카테고리 필터 JSON" },
        { "name": "requested_count", "type": "INTEGER", "required": true, "description": "운영자가 요청한 기사 수" },
        { "name": "candidate_count", "type": "INTEGER", "required": true, "default": 0, "description": "수집된 후보 수" },
        { "name": "queued_count", "type": "INTEGER", "required": true, "default": 0, "description": "큐 대기 상태로 등록된 item 수" },
        { "name": "processing_count", "type": "INTEGER", "required": true, "default": 0, "description": "처리 중 item 수" },
        { "name": "published_count", "type": "INTEGER", "required": true, "default": 0, "description": "기사 등록 완료 수" },
        { "name": "skipped_count", "type": "INTEGER", "required": true, "default": 0, "description": "중복, 이미지 없음, 정책 제외 수" },
        { "name": "failed_count", "type": "INTEGER", "required": true, "default": 0, "description": "실패 수" },
        { "name": "ai_call_count", "type": "INTEGER", "required": true, "default": 0, "description": "이 실행에서 사용한 AI 호출 수" },
        { "name": "image_upload_count", "type": "INTEGER", "required": true, "default": 0, "description": "이 실행에서 업로드한 이미지 수" },
        { "name": "message", "type": "TEXT", "required": false, "description": "관리자 화면 요약 메시지" },
        { "name": "started_at", "type": "TEXT", "required": false, "description": "실제 처리 시작 시각 ISO 문자열" },
        { "name": "finished_at", "type": "TEXT", "required": false, "description": "완료 또는 실패 시각 ISO 문자열" },
        { "name": "created_by", "type": "TEXT", "required": false, "description": "관리자 ID 또는 system" },
        { "name": "created_at", "type": "TEXT", "required": true, "description": "생성 시각 ISO 문자열" },
        { "name": "updated_at", "type": "TEXT", "required": true, "description": "수정 시각 ISO 문자열" }
      ],
      "indexes": [
        "idx_auto_press_runs_created_at",
        "idx_auto_press_runs_status",
        "idx_auto_press_runs_trigger_type"
      ]
    },
    "auto_press_items": {
      "description": "기사 후보 단위 처리 상태. 후보 하나가 하나의 item이다.",
      "columns": [
        { "name": "id", "type": "TEXT", "required": true, "description": "UUID 또는 ulid 작업 ID" },
        { "name": "run_id", "type": "TEXT", "required": true, "description": "auto_press_runs.id" },
        { "name": "source_id", "type": "TEXT", "required": true, "description": "수집 소스 ID" },
        { "name": "source_name", "type": "TEXT", "required": false, "description": "수집 소스명" },
        { "name": "source_type", "type": "TEXT", "required": false, "description": "newswire, government, foundation, custom_rss 등" },
        { "name": "external_id", "type": "TEXT", "required": false, "description": "외부 보도자료 번호 또는 RSS GUID" },
        { "name": "source_url", "type": "TEXT", "required": true, "description": "원문 URL" },
        { "name": "canonical_url", "type": "TEXT", "required": false, "description": "정규화된 원문 URL" },
        { "name": "title", "type": "TEXT", "required": false, "description": "수집 원문 제목" },
        { "name": "normalized_title", "type": "TEXT", "required": false, "description": "중복 검사용 제목" },
        { "name": "published_at", "type": "TEXT", "required": false, "description": "원문 발행 시각" },
        { "name": "status", "type": "TEXT", "required": true, "description": "pending, queued, collecting, skipped_duplicate, skipped_no_image, waiting_ai, ai_editing, copyright_check_failed, publishing, published, failed, cancelled" },
        { "name": "priority", "type": "INTEGER", "required": true, "default": 100, "description": "낮을수록 먼저 처리" },
        { "name": "attempt_count", "type": "INTEGER", "required": true, "default": 0, "description": "처리 시도 횟수" },
        { "name": "max_attempts", "type": "INTEGER", "required": true, "default": 3, "description": "최대 재시도 횟수" },
        { "name": "next_retry_at", "type": "TEXT", "required": false, "description": "다음 재시도 가능 시각" },
        { "name": "lease_until", "type": "TEXT", "required": false, "description": "중복 처리 방지용 작업 점유 만료 시각" },
        { "name": "failure_code", "type": "TEXT", "required": false, "description": "표준 실패 코드" },
        { "name": "failure_message", "type": "TEXT", "required": false, "description": "관리자용 한글 실패 사유" },
        { "name": "image_url", "type": "TEXT", "required": false, "description": "확인된 대표 이미지 URL" },
        { "name": "image_check_json", "type": "TEXT", "required": false, "description": "이미지 검사 결과 JSON" },
        { "name": "ai_provider", "type": "TEXT", "required": false, "description": "gemini, openai 등" },
        { "name": "ai_model", "type": "TEXT", "required": false, "description": "AI 모델명" },
        { "name": "article_id", "type": "TEXT", "required": false, "description": "등록된 기사 ID" },
        { "name": "article_no", "type": "INTEGER", "required": false, "description": "등록된 기사 번호" },
        { "name": "created_at", "type": "TEXT", "required": true, "description": "생성 시각 ISO 문자열" },
        { "name": "updated_at", "type": "TEXT", "required": true, "description": "수정 시각 ISO 문자열" }
      ],
      "indexes": [
        "idx_auto_press_items_run",
        "idx_auto_press_items_status",
        "idx_auto_press_items_source_url",
        "idx_auto_press_items_reason"
      ],
      "uniqueGuards": [
        {
          "name": "unique_source_url_when_available",
          "description": "source_url 또는 canonical_url 기준 중복 후보 생성을 방지한다."
        },
        {
          "name": "unique_external_id_per_source_when_available",
          "description": "source_id + external_id 기준 중복 후보 생성을 방지한다."
        }
      ]
    },
    "auto_press_events": {
      "description": "run과 item에서 발생한 이벤트 로그. 디버깅과 운영자 확인을 위한 상세 기록이다.",
      "columns": [
        { "name": "id", "type": "TEXT", "required": true, "description": "이벤트 ID" },
        { "name": "run_id", "type": "TEXT", "required": false, "description": "실행 ID" },
        { "name": "item_id", "type": "TEXT", "required": false, "description": "작업 ID" },
        { "name": "level", "type": "TEXT", "required": true, "description": "info, warning, error" },
        { "name": "event_code", "type": "TEXT", "required": true, "description": "표준 이벤트 코드" },
        { "name": "message", "type": "TEXT", "required": true, "description": "관리자용 한글 메시지" },
        { "name": "meta_json", "type": "TEXT", "required": false, "description": "원인 분석용 JSON" },
        { "name": "created_at", "type": "TEXT", "required": true, "description": "생성 시각 ISO 문자열" }
      ],
      "indexes": [
        "idx_auto_press_events_run_id_created_at",
        "idx_auto_press_events_item_id_created_at",
        "idx_auto_press_events_event_code",
        "idx_auto_press_events_level"
      ]
    },
    "auto_press_source_stats": {
      "description": "소스별 품질과 효율을 집계해 비효율 소스를 찾아낸다.",
      "columns": [
        { "name": "date", "type": "TEXT", "required": true, "description": "KST 기준 날짜 YYYY-MM-DD" },
        { "name": "source_id", "type": "TEXT", "required": true, "description": "수집 소스 ID" },
        { "name": "source_name", "type": "TEXT", "required": false, "description": "수집 소스명" },
        { "name": "candidate_count", "type": "INTEGER", "required": true, "default": 0, "description": "후보 수" },
        { "name": "duplicate_count", "type": "INTEGER", "required": true, "default": 0, "description": "중복 제외 수" },
        { "name": "no_image_count", "type": "INTEGER", "required": true, "default": 0, "description": "이미지 없음 제외 수" },
        { "name": "ai_call_count", "type": "INTEGER", "required": true, "default": 0, "description": "AI 호출 수" },
        { "name": "published_count", "type": "INTEGER", "required": true, "default": 0, "description": "등록 완료 수" },
        { "name": "failed_count", "type": "INTEGER", "required": true, "default": 0, "description": "실패 수" },
        { "name": "updated_at", "type": "TEXT", "required": true, "description": "수정 시각 ISO 문자열" }
      ],
      "indexes": [
        "idx_auto_press_source_stats_date",
        "idx_auto_press_source_stats_source_id"
      ],
      "primaryKey": ["date", "source_id"]
    }
  },
  "stateMachines": {
    "runStatus": {
      "initial": "queued",
      "terminal": ["completed", "failed", "cancelled"],
      "transitions": [
        { "from": "queued", "to": "collecting", "reason": "후보 수집 시작" },
        { "from": "collecting", "to": "waiting_worker", "reason": "후보 생성 완료 후 Worker 처리 대기" },
        { "from": "waiting_worker", "to": "processing", "reason": "하나 이상의 job 처리 시작" },
        { "from": "processing", "to": "completed", "reason": "모든 item이 terminal 상태 도달" },
        { "from": "queued", "to": "cancelled", "reason": "운영자 취소" },
        { "from": "collecting", "to": "failed", "reason": "후보 수집 중 치명적 실패" },
        { "from": "waiting_worker", "to": "cancelled", "reason": "운영자 취소" },
        { "from": "processing", "to": "failed", "reason": "시스템 장애 또는 일괄 실패" }
      ]
    },
    "itemStatus": {
