  "apiDesign": {
    "adminEndpoints": [
      {
        "method": "GET",
        "path": "/api/auto-press/runs",
        "purpose": "최근 자동등록 실행 목록 조회",
        "query": [
          "status",
          "trigger_type",
          "date_from",
          "date_to",
          "limit",
          "cursor"
        ],
        "responseShape": {
          "success": true,
          "runs": "AutoPressRunSummary[]",
          "nextCursor": "string|null"
        }
      },
      {
        "method": "POST",
        "path": "/api/auto-press/runs",
        "purpose": "수동 실행 run 생성",
        "body": [
          "sourceIds",
          "dateRangeDays",
          "requestedCount",
          "preview",
          "forcePast",
          "requireImage"
        ],
        "responseShape": {
          "success": true,
          "runId": "string",
          "status": "queued",
          "message": "string"
        }
      },
      {
        "method": "GET",
        "path": "/api/auto-press/runs/[id]",
        "purpose": "특정 실행 상세 조회",
        "responseShape": {
          "success": true,
          "run": "AutoPressRunDetail",
          "items": "AutoPressItemSummary[]",
          "events": "AutoPressEvent[]"
        }
      },
      {
        "method": "POST",
        "path": "/api/auto-press/runs/[id]/cancel",
        "purpose": "대기 중이거나 처리 중인 실행 취소",
        "responseShape": {
          "success": true,
          "status": "cancelled",
          "message": "string"
        }
      },
      {
        "method": "GET",
        "path": "/api/auto-press/source-stats",
        "purpose": "소스별 등록 효율과 제외 사유 통계 조회",
        "query": [
          "date_from",
          "date_to",
          "source_id"
        ],
        "responseShape": {
          "success": true,
          "stats": "AutoPressSourceStats[]"
        }
      }
    ],
    "security": [
      "모든 endpoint는 관리자 인증을 요구한다.",
