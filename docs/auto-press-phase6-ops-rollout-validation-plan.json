  "developmentGuardrails": {
    "migrationReuseRule": {
      "description": "Phase2 착수 시 현재 D1 migration을 재사용하고 필요한 컬럼만 additive migration으로 추가한다.",
      "mustFollow": [
        "cloudflare/d1/migrations/0002_auto_press_observability.sql을 기준 스키마로 본다.",
        "auto_press_runs, auto_press_items, auto_press_events, auto_press_retry_queue를 재생성하지 않는다.",
        "기존 src/lib/auto-press-observability.ts와 src/types/article.ts의 필드명을 우선한다.",
        "필요한 컬럼은 새 migration 파일로만 추가한다.",
        "새 컬럼은 기존 row와 기존 API를 깨지 않도록 NULL 허용 또는 DEFAULT 값을 둔다."
      ],
      "mustAvoid": [
        "auto_press_jobs 테이블 신설",
        "기존 migration 파일 수정",
        "reason_code/reason_message를 failure_code/failure_message로 일괄 치환",
        "events.code/metadata_json을 event_code/meta_json으로 일괄 치환",
        "D1 기준을 다시 Supabase REST 기준으로 되돌리는 설계"
      ]
    },
    "namingGuardrails": {
      "description": "문서와 코드에서 item/job 용어 혼선이 생기지 않도록 개발 기준을 고정한다.",
      "rules": [
        "DB 테이블명은 auto_press_items를 사용한다.",
        "TypeScript 내부 도메인 타입은 Item 기준을 우선한다.",
        "Cloudflare Queue 리소스 이름은 생성 전 최종 확정한다. 이미 auto-press-jobs로 생성했다면 리소스명은 유지하되 메시지 필드는 itemId로 고정한다.",
        "관리자 화면 문구는 운영자가 이해하기 쉽게 '기사 후보' 또는 '작업'으로 표시한다."
      ]
    }
  },
