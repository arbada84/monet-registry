{
  "document": {
    "title": "보도자료 자동등록 6단계 통합 검증, 비용 모니터링 및 운영 전환 상세 기획서",
    "version": "2026-05-11",
    "status": "implemented",
    "language": "ko-KR",
    "parentPlans": [
      "docs/auto-press-vercel-cpu-distribution-plan.json",
      "docs/auto-press-phase1-vercel-cpu-defense-plan.json",
      "docs/auto-press-phase2-d1-observability-plan.json",
      "docs/auto-press-phase3-cloudflare-worker-queue-plan.json",
      "docs/auto-press-phase4-telegram-ops-plan.json",
      "docs/auto-press-phase5-public-page-cpu-cache-plan.json"
    ],
    "developmentStarted": true,
    "summary": "자동등록 분산 처리 전체 기능을 운영에 안전하게 적용하기 위한 통합 검증, 단계별 배포, 비용 모니터링, 장애 대응, 롤백, 운영자 체크리스트를 정의한다."
  },
  "purpose": {
    "why": "자동등록 구조 변경은 Vercel, Cloudflare Worker, D1, R2, AI provider, Telegram, 관리자 화면을 모두 건드리므로 기능 구현만으로는 충분하지 않다.",
    "goal": "운영 중단 없이 단계적으로 적용하고, 비용 초과와 중복 등록, 저작권 유사도, 이미지 누락, 알림 장애를 조기에 발견한다.",
    "result": "보도자료 자동등록은 켜진 상태로 안정 운영되고, 기사 자동발행은 꺼진 상태를 유지하며, Vercel CPU와 AI 토큰 사용량은 관리 가능한 범위에 들어온다."
  },
  "successDefinition": {
    "functional": [
      "보도자료 자동등록은 정상적으로 작업을 예약하고 순차 처리한다.",
      "기사 자동발행 기능은 꺼져 있다.",
      "이미지 없는 보도자료는 자동등록되지 않는다.",
      "중복 기사는 자동등록되지 않는다.",
      "AI 편집 없는 원문 그대로의 등록은 차단된다.",
      "관리자는 실행 현황과 실패 사유를 확인할 수 있다.",
      "텔레그램 리포트와 경고가 한글로 정상 수신된다."
    ],
    "cost": [
      "Vercel Fluid Active CPU 증가 속도가 기존 대비 유의미하게 감소한다.",
      "AI 호출은 이미지/중복/소스 필터 이후에만 발생한다.",
      "Cloudflare Worker, D1, R2 사용량은 일일 리포트로 추적된다.",
      "일일 상한에 도달하면 남은 작업은 다음 처리로 넘어간다."
    ],
    "reliability": [
      "Worker 재시도 중에도 같은 기사가 중복 등록되지 않는다.",
      "Queue 또는 Worker 장애 시 Vercel 사이트 화면은 계속 동작한다.",
      "텔레그램 발송 실패가 기사 등록 실패로 전파되지 않는다.",
      "새 테이블과 새 API 장애가 기존 기사 데이터에 영향을 주지 않는다."
    ]
  },
