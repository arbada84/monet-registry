      },
      {
        "command": "/실패",
        "aliases": ["/failures"],
        "riskLevel": "safe",
        "description": "최근 실패 사유와 소스별 실패율을 조회한다.",
        "requiresConfirmation": false
      },
      {
        "command": "/기사비공개",
        "aliases": ["/hide_article"],
        "riskLevel": "high",
        "description": "특정 기사 번호를 비공개로 전환한다.",
        "parameters": ["article_no"],
        "requiresConfirmation": true,
        "confirmationReason": "공개 기사 상태를 변경한다."
      },
      {
        "command": "/기사삭제",
        "aliases": ["/delete_article"],
        "riskLevel": "critical",
        "description": "특정 기사를 삭제한다. 기본은 비활성화하고 비공개 전환을 권장한다.",
        "parameters": ["article_no"],
        "requiresConfirmation": true,
        "defaultEnabled": false,
        "confirmationReason": "복구 어려운 데이터 변경이므로 기본 차단한다."
      },
      {
        "command": "/점검모드",
        "aliases": ["/maintenance"],
