{
  "document": {
    "title": "보도자료 자동등록 4단계 텔레그램 운영 리포트 및 명령 기능 상세 기획서",
    "version": "2026-05-11",
    "status": "implemented",
    "language": "ko-KR",
    "parentPlans": [
      "docs/auto-press-vercel-cpu-distribution-plan.json",
      "docs/auto-press-phase1-vercel-cpu-defense-plan.json",
      "docs/auto-press-phase2-d1-observability-plan.json",
      "docs/auto-press-phase3-cloudflare-worker-queue-plan.json"
    ],
    "developmentStarted": true,
    "summary": "보도자료 자동등록 실행 결과, 실패 사유, 비용 사용량, 긴급 제어 명령을 텔레그램으로 제공해 운영자가 관리자 화면에 접속하지 못해도 상태를 파악하고 대응할 수 있게 한다."
  },
  "purpose": {
    "why": "자동등록이 백그라운드 큐로 이동하면 버튼 클릭 직후 결과를 볼 수 없으므로, 운영자는 진행 상황과 실패 사유를 실시간 또는 정기 리포트로 받아야 한다.",
    "goal": "텔레그램을 자동등록 운영 알림, 비용 감시, 긴급 제어 채널로 사용한다.",
    "result": "운영자는 매일 오전 리포트, 실행 완료 요약, 실패 급증 경고를 받고, 제한된 명령으로 자동등록 일시중지/재개/상태조회/수동실행 예약을 할 수 있다."
  },
  "scope": {
    "included": [
      "텔레그램 알림 종류 정의",
      "일일 운영 리포트 설계",
      "자동등록 실행 완료 요약",
      "실패율 급증 경고",
      "Cloudflare/Vercel 사용량 위험 알림",
      "명령어 설계",
      "권한과 승인 절차",
      "한글 인코딩과 메시지 포맷 표준",
      "명령 실행 감사 로그",
      "관리자 화면 설정 연동"
    ],
    "excluded": [
      "일반 사용자 대상 텔레그램 봇 기능",
      "그룹 채팅 기반 다중 운영자 워크플로우",
      "메일 첨부파일 전체 텔레그램 전송",
      "기사 본문 전체 텔레그램 전송",
      "텔레그램 결제 기능"
    ]
  },
  "securityPrinciples": [
    {
      "principle": "허용된 chat_id만 명령 가능",
      "description": "봇 토큰을 알더라도 등록된 관리자 chat_id가 아니면 상태 조회 외 모든 명령을 거부한다."
    },
    {
      "principle": "위험 명령은 2단계 확인",
      "description": "기사 삭제, 자동등록 대량 실행, 사이트 점검모드 전환 같은 위험 명령은 확인 토큰을 다시 입력해야 실행한다."
    },
    {
      "principle": "비밀값은 절대 메시지로 보내지 않음",
      "description": "API 키, 봇 토큰, 관리자 세션, DB URL, Cloudflare 토큰은 텔레그램 메시지와 로그에 포함하지 않는다."
    },
    {
      "principle": "명령은 감사 로그에 남김",
      "description": "누가, 언제, 어떤 명령을 실행했는지 D1에 기록한다."
    },
    {
      "principle": "삭제보다 비활성 우선",
      "description": "텔레그램 명령으로 기사를 바로 삭제하는 기능은 기본 비활성으로 두고, 우선 비공개 전환만 허용한다."
    }
  ],
  "telegramBotConfig": {
    "botUsername": "culturepeople_bot",
    "requiredEnvironment": [
      {
        "name": "TELEGRAM_BOT_TOKEN",
        "location": "Cloudflare Worker secret and Vercel env",
        "description": "텔레그램 봇 토큰. 코드와 로그에 직접 노출하지 않는다."
      },
      {
        "name": "TELEGRAM_ADMIN_CHAT_IDS",
        "location": "D1 setting or environment variable",
        "description": "쉼표로 구분된 관리자 chat_id 목록"
      },
      {
        "name": "TELEGRAM_ALERTS_ENABLED",
        "location": "site setting",
        "description": "운영 알림 전체 활성화 여부"
      }
    ],
    "encodingPolicy": [
      "sendMessage는 UTF-8 JSON payload로 전송한다.",
      "PowerShell 또는 shell을 통해 직접 curl 호출할 때는 인코딩 깨짐 위험이 있으므로 서버 코드에서 fetch API로 보낸다.",
      "parse_mode는 기본 HTML을 사용하되, 제목과 본문은 HTML escape 처리한다.",
      "긴 메시지는 3500자 이하로 나누어 보낸다."
    ]
  },
